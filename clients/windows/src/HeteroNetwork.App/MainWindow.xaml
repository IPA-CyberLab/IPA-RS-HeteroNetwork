<Window x:Class="HeteroNetwork.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HeteroNetwork"
        Width="760"
        Height="650"
        MinWidth="680"
        MinHeight="570"
        WindowStartupLocation="CenterScreen">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="#172033" Padding="30,24">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Border Width="48" Height="48" CornerRadius="14" Background="#2563EB">
          <TextBlock Text="⬡"
                     Foreground="White"
                     FontSize="29"
                     FontWeight="SemiBold"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center" />
        </Border>
        <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
          <TextBlock Text="HeteroNetwork"
                     Foreground="White"
                     FontSize="23"
                     FontWeight="SemiBold" />
          <TextBlock Text="Windows control-only client"
                     Foreground="#AEB8CD"
                     FontSize="13" />
        </StackPanel>
        <Border Grid.Column="2"
                Background="#263149"
                CornerRadius="16"
                Padding="13,7"
                VerticalAlignment="Center">
          <StackPanel Orientation="Horizontal">
            <Ellipse Width="8"
                     Height="8"
                     Margin="0,0,8,0"
                     Fill="{Binding StatusBrush}" />
            <TextBlock Text="{Binding StatusDisplay}"
                       Foreground="White"
                       FontWeight="SemiBold"
                       FontSize="12" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="30,26,30,22">
        <Border Style="{StaticResource CardStyle}"
                Margin="0,0,0,16"
                Background="#FFF9E8"
                BorderBrush="#F5D77A"
                Visibility="{Binding WireGuardMissing, Converter={StaticResource BooleanToVisibilityConverter}}">
          <Grid>
            <StackPanel>
              <TextBlock Text="Embedded WireGuard runtime is unavailable"
                         FontWeight="SemiBold"
                         FontSize="15" />
              <TextBlock Margin="0,5,0,0"
                         Foreground="#725A13"
                         Text="Rebuild the Windows client to restore its pinned WireGuard runtime." />
            </StackPanel>
          </Grid>
        </Border>

        <Border Style="{StaticResource CardStyle}"
                Visibility="{Binding IsNotConfigured, Converter={StaticResource BooleanToVisibilityConverter}}">
          <StackPanel>
            <TextBlock Text="Enroll this PC"
                       FontSize="21"
                       FontWeight="SemiBold" />
            <TextBlock Margin="0,7,0,20"
                       Foreground="{StaticResource MutedInkBrush}"
                       Text="Paste the one-use desktop client link generated by the HeteroNetwork Web UI. The token is kept in memory only." />
            <TextBlock Text="Enrollment link"
                       FontWeight="SemiBold"
                       Margin="0,0,0,7" />
            <PasswordBox x:Name="EnrollmentLink"
                         Padding="11,9"
                         FontFamily="Consolas"
                         FontSize="12"
                         PasswordChanged="EnrollmentLink_PasswordChanged" />
            <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
              <Button Style="{StaticResource PrimaryButton}"
                      Content="Enroll this PC"
                      IsEnabled="{Binding CanEnroll}"
                      Click="Enroll_Click" />
              <ProgressBar Width="100"
                           Height="4"
                           Margin="16,0,0,0"
                           IsIndeterminate="True"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <StackPanel Visibility="{Binding IsConfigured, Converter={StaticResource BooleanToVisibilityConverter}}">
          <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
            <StackPanel>
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                  <TextBlock Text="Connection"
                             FontSize="21"
                             FontWeight="SemiBold" />
                  <TextBlock Text="Gateway-only WireGuard tunnel"
                             Foreground="{StaticResource MutedInkBrush}"
                             Margin="0,4,0,0" />
                </StackPanel>
                <ProgressBar Grid.Column="1"
                             Width="100"
                             Height="4"
                             IsIndeterminate="True"
                             VerticalAlignment="Center"
                             Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}" />
              </Grid>

              <Grid Margin="0,22,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="145" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="VPN address" Foreground="{StaticResource MutedInkBrush}" Margin="0,0,0,12" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding VpnAddress}" FontFamily="Consolas" FontWeight="SemiBold" />
                <TextBlock Grid.Row="1" Text="Gateway" Foreground="{StaticResource MutedInkBrush}" Margin="0,0,0,12" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GatewayName}" FontFamily="Consolas" />
                <TextBlock Grid.Row="2" Text="Cluster" Foreground="{StaticResource MutedInkBrush}" Margin="0,0,0,12" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ClusterName}" />
                <TextBlock Grid.Row="3" Text="Last refresh" Foreground="{StaticResource MutedInkBrush}" />
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LastRefresh}" />
              </Grid>

              <WrapPanel Margin="0,22,0,0">
                <Button Style="{StaticResource PrimaryButton}"
                        Content="{Binding ConnectionAction}"
                        Click="Connection_Click"
                        Margin="0,0,10,8" />
                <Button Style="{StaticResource SecondaryButton}"
                        Content="Refresh"
                        Click="Refresh_Click"
                        Margin="0,0,10,8" />
                <Button Style="{StaticResource SecondaryButton}"
                        Content="Open Web UI"
                        Click="OpenWebUi_Click"
                        IsEnabled="{Binding IsConnected}"
                        Margin="0,0,10,8" />
              </WrapPanel>
              <TextBlock Margin="0,7,0,0"
                         Foreground="{StaticResource MutedInkBrush}"
                         FontSize="12"
                         Text="Windows will ask for administrator approval when the tunnel configuration changes." />
            </StackPanel>
          </Border>

          <Border Style="{StaticResource CardStyle}">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="Identity" FontSize="17" FontWeight="SemiBold" />
                <TextBlock Text="{Binding ClientId}"
                           FontFamily="Consolas"
                           FontSize="12"
                           Foreground="{StaticResource MutedInkBrush}"
                           Margin="0,7,18,0" />
              </StackPanel>
              <Button Grid.Column="1"
                      Style="{StaticResource DangerButton}"
                      Content="Remove this PC"
                      Click="Remove_Click"
                      VerticalAlignment="Center" />
            </Grid>
          </Border>
        </StackPanel>

        <Border Style="{StaticResource CardStyle}"
                Margin="0,16,0,0"
                Background="#FFF1F2"
                BorderBrush="#FECDD3"
                Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
              <TextBlock Text="Something went wrong"
                         Foreground="#B42318"
                         FontWeight="SemiBold" />
              <TextBlock Text="{Binding LastError}"
                         Foreground="#912018"
                         Margin="0,5,12,0" />
            </StackPanel>
            <Button Grid.Column="1"
                    Content="Dismiss"
                    Style="{StaticResource DangerButton}"
                    Click="DismissError_Click"
                    VerticalAlignment="Center" />
          </Grid>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Border Grid.Row="2" Background="#E9EDF5" Padding="30,10">
      <TextBlock Foreground="{StaticResource MutedInkBrush}"
                 FontSize="11"
                 Text="HeteroNetwork 0.1.0 · Keys protected with Windows DPAPI · Split DNS for console.heteronetwork.internal" />
    </Border>
  </Grid>
</Window>
