<Application x:Class="HeteroNetwork.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Application.Resources>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

    <Color x:Key="Ink">#172033</Color>
    <Color x:Key="MutedInk">#667085</Color>
    <Color x:Key="Brand">#2563EB</Color>
    <Color x:Key="BrandDark">#1D4ED8</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="Canvas">#F2F5FA</Color>
    <Color x:Key="Line">#E4E7EC</Color>

    <SolidColorBrush x:Key="InkBrush" Color="{StaticResource Ink}" />
    <SolidColorBrush x:Key="MutedInkBrush" Color="{StaticResource MutedInk}" />
    <SolidColorBrush x:Key="BrandBrush" Color="{StaticResource Brand}" />
    <SolidColorBrush x:Key="BrandDarkBrush" Color="{StaticResource BrandDark}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}" />
    <SolidColorBrush x:Key="CanvasBrush" Color="{StaticResource Canvas}" />
    <SolidColorBrush x:Key="LineBrush" Color="{StaticResource Line}" />

    <Style TargetType="Window">
      <Setter Property="FontFamily" Value="Segoe UI" />
      <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
      <Setter Property="Background" Value="{StaticResource CanvasBrush}" />
    </Style>

    <Style TargetType="TextBlock">
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style x:Key="CardStyle" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="24" />
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button">
      <Setter Property="Background" Value="{StaticResource BrandBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="18,10" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Border"
                    Background="{TemplateBinding Background}"
                    CornerRadius="7"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Border" Property="Background" Value="{StaticResource BrandDarkBrush}" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Border" Property="Opacity" Value="0.45" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
      <Setter Property="Background" Value="#EEF4FF" />
      <Setter Property="Foreground" Value="{StaticResource BrandDarkBrush}" />
      <Setter Property="BorderBrush" Value="#C7D7FE" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Border"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="7"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Border" Property="Background" Value="#E0EAFF" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Border" Property="Opacity" Value="0.45" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
      <Setter Property="Background" Value="#FFF1F2" />
      <Setter Property="Foreground" Value="#B42318" />
      <Setter Property="BorderBrush" Value="#FECDD3" />
    </Style>
  </Application.Resources>
</Application>
