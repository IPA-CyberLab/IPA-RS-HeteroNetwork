# Copy to /etc/ipars/public-node.env with mode 0640 and ownership root:ipars.
# Every public node uses the same cluster/database/issuer values and unique
# instance, listen, and advertised endpoint values.

HETERONETWORK_CLUSTER_ID=heteronetwork-production
HETERONETWORK_VPN_POOL=10.250.0.0/16
HETERONETWORK_DATABASE_URL=postgresql://heteronetwork:CHANGE_ME@postgres.example:5432/heteronetwork?sslmode=require
HETERONETWORK_ISSUER_NODE_ID=CHANGE_ME
HETERONETWORK_ISSUER_KEY_ID=root
HETERONETWORK_ISSUER_PUBLIC_KEY=CHANGE_ME

HETERONETWORK_SERVICE_INSTANCE_ID=public-a
HETERONETWORK_SERVICE_LEASE_TTL_SECONDS=30
HETERONETWORK_SERVICE_LEASE_RENEW_INTERVAL_SECONDS=10
HETERONETWORK_ADVERTISE_CONTROL_PLANE_URL=https://public-a.example:8443
HETERONETWORK_ADVERTISE_SIGNAL_URL=https://public-a.example:9443
HETERONETWORK_ADVERTISE_STUN_URL=udp://public-a.example:3478
HETERONETWORK_ADVERTISE_RELAY_URL=udp://public-a.example:51820

HETERONETWORK_LISTEN=0.0.0.0:8443
HETERONETWORK_SIGNAL_LISTEN=0.0.0.0:9443
HETERONETWORK_SIGNAL_CONTROL_PLANE_URLS=https://public-a.example:8443,https://public-b.example:8443
HETERONETWORK_STUN_LISTEN=0.0.0.0:3478
HETERONETWORK_STUN_ALTERNATE_LISTEN=0.0.0.0:3480
HETERONETWORK_STUN_HTTP_LISTEN=0.0.0.0:3479
HETERONETWORK_RELAY_NODE_ID=public-a
HETERONETWORK_RELAY_UDP_LISTEN=0.0.0.0:51820
HETERONETWORK_RELAY_HTTP_LISTEN=0.0.0.0:9580
HETERONETWORK_RELAY_PUBLIC_ENDPOINT=203.0.113.10:51820
HETERONETWORK_RELAY_ADMISSION_URL=https://public-a.example:9580

HETERONETWORK_CONTROL_PLANE_OPERATOR_API_BEARER_TOKEN_PATH=/etc/ipars/control-plane-operator.token
HETERONETWORK_SIGNAL_OPERATOR_API_BEARER_TOKEN_PATH=/etc/ipars/signal-operator.token
HETERONETWORK_STUN_OPERATOR_API_BEARER_TOKEN_PATH=/etc/ipars/stun-operator.token
HETERONETWORK_RELAY_OPERATOR_API_BEARER_TOKEN_PATH=/etc/ipars/relay-operator.token
HETERONETWORK_RELAY_ADMISSION_BEARER_TOKEN_PATH=/etc/ipars/relay-admission.token

HETERONETWORK_WEB_UI_ENABLED=true
HETERONETWORK_WEB_AUTH_PROVIDER=keycloak
HETERONETWORK_WEB_PUBLIC_URL=https://public-a.example:8443
HETERONETWORK_WEB_OIDC_ISSUER_URL=https://sso.example/realms/heteronetwork
HETERONETWORK_WEB_OIDC_CLIENT_ID=heteronetwork-web
HETERONETWORK_WEB_OIDC_SCOPES=openid profile email

# Optional Add device workflow. Use the same dedicated signing key on every
# Control Plane replica; never point this at the offline root issuer key.
HETERONETWORK_NODE_ENROLLMENT_ENABLED=true
# The systemd unit loads /etc/credstore/node-enrollment-issuer.key. Direct
# daemon invocations can instead set HETERONETWORK_NODE_ENROLLMENT_ISSUER_PRIVATE_KEY_PATH.
HETERONETWORK_NODE_ENROLLMENT_ISSUER_KEY_ID=web-enrollment
HETERONETWORK_NODE_ENROLLMENT_MAX_TTL_SECONDS=604800
HETERONETWORK_NODE_ENROLLMENT_BINARY_PATH=/opt/ipars/bin/iparsd

# Set these on all four processes when an OpenTelemetry Collector is available.
# HETERONETWORK_OTEL_ENABLED=true
# HETERONETWORK_OTEL_ENDPOINT=https://otel.example:4318
HETERONETWORK_LOG_FILTER=info
